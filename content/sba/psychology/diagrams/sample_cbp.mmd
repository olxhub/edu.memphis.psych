flowchart LR
settingEvent["<h1>Setting Event</h1><br/>Student arrives at school feeling anxious."]
triggeringAntecedent["<h1>Triggering Antecedent</h1><br/>Task is too long or too difficult."]
problemBehavior["<h1>Problem Behavior</h1><br/>Student puts head down and hopes the teacher won't notice."]
maintainingConsequence["<h1>Maintaining Consequence</h1><br/>Student avoids the task and/or the adult placing the demand on him. (Escape)"]
desiredBehavior["<h1>Desired Behavior</h1><br/>Student asks their teacher for help."]
desiredConsequence["<h1>Desired Consequence</h1><br/>Student teacher helps them for help."]
alternativeBehavior["<h1>Alternative Behavior</h1><br/>Student starts arguing with the teacher or even leaves the classroom."]
problemStatement["<h1>Problem Statement</h1><br/>When a student is presented with a work demand that is too difficult or too long, they may put their head down and stop working, or even worse, refuse, argue, or leave the classroom in order to escape the task and/or the adult placing the demand on him."]

settingEvent --> triggeringAntecedent
desiredBehavior --> desiredConsequence
alternativeBehavior --> maintainingConsequence
triggeringAntecedent --> desiredBehavior
triggeringAntecedent --> problemBehavior
triggeringAntecedent --> alternativeBehavior
problemBehavior --> maintainingConsequence

class settingEvent,triggeringAntecedent context
class desiredBehavior,desiredConsequence desired
class problemBehavior problem
class maintainingConsequence consequence
class alternativeBehavior alternative
class problemStatement statement
classDef context fill:#ffe6cc,stroke:#cc7a00,stroke-width:2px,color:#000;
classDef desired fill:#d9edf7,stroke:#31708f,stroke-width:2px,color:#000;
classDef problem fill:#f8d7da,stroke:#a94442,stroke-width:2px,color:#000;
classDef consequence fill:#e2e3e5,stroke:#6c757d,stroke-width:2px,color:#000;
classDef alternative fill:#e8dff5,stroke:#7a5ea6,stroke-width:2px,color:#000;
classDef statement fill:#f5f5f5,stroke:#888,stroke-dasharray:5 5,color:#000;
